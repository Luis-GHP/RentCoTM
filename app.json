{
  "expo": {
    "name": "RentCo",
    "slug": "rentco",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/rentco-app-icon.png",
    "scheme": "rentco",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.rentco.app"
    },
    "android": {
      "package": "com.rentco.app",
      "adaptiveIcon": {
        "backgroundColor": "#2F4A7D",
        "foregroundImage": "./assets/images/rentco-adaptive-icon-foreground.png",
        "monochromeImage": "./assets/images/rentco-adaptive-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/rentco-favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/rentco-splash-logo.png",
          "imageWidth": 240,
          "resizeMode": "contain",
          "backgroundColor": "#2F4A7D"
        }
      ],
      "expo-notifications",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
